    <worksheet name='Ship Mode Bar'>
      <table>
        <view>
          <datasources>
            <datasource caption='Superstore' name='federated.040hhjl0wee1oo1cz26we1dstxlh' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Year Selected' datatype='integer' default-format='n0;(0)' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='2013'>
              <calculation class='tableau' formula='2013' />
            </column>
            <column alias='PROFIT' caption='Metric Swap Param' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Profit&quot;'>
              <calculation class='tableau' formula='&quot;Profit&quot;' />
              <aliases>
                <alias key='&quot;Orders&quot;' value='ORDERS' />
                <alias key='&quot;Profit&quot;' value='PROFIT' />
                <alias key='&quot;Sales&quot;' value='SALES' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.040hhjl0wee1oo1cz26we1dstxlh'>
            <column caption='Sales Selected Year' datatype='real' name='[Calculation_1055531173119102976]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 1]&#13;&#10;THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='Selected Year' datatype='integer' name='[Calculation_1055531173123846149]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]' />
            </column>
            <column caption='Metric Swap Calc' datatype='real' name='[Calculation_1055531173171879959]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Sales&quot; THEN ZN(SUM([Calculation_1055531173119102976]))&#13;&#10;WHEN &quot;Profit&quot; THEN ZN(SUM([Sales Selected Year (copy)_1055531173139935251]))&#13;&#10;WHEN &quot;Orders&quot; THEN ZN(COUNTD([Sales Selected Year (copy) (copy)_1055531173139943444]))&#13;&#10;END' />
            </column>
            <column caption='Metric Swap Calc PY' datatype='real' name='[Metric Swap Calc (copy)_1055531173173067800]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Sales&quot; THEN ZN(SUM([Sales Selected Year (copy)_1055531173119610881]))&#13;&#10;WHEN &quot;Profit&quot; THEN ZN(SUM([Sales Previous Year (copy)_1055531173139865616]))&#13;&#10;WHEN &quot;Orders&quot; THEN ZN(COUNTD([Sales Previous Year (copy) (copy)_1055531173139894289]))&#13;&#10;END' />
            </column>
            <column caption='Metric Swap Calc (Label)' datatype='string' name='[Metric Swap Calc (copy)_1055531173173567513]' role='measure' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Sales&quot; THEN &quot;$&quot; + STR(ROUND((SUM([Calculation_1055531173119102976])/1000),1)) + &quot;K&quot;&#13;&#10;WHEN &quot;Profit&quot; THEN &quot;$&quot; + STR(ROUND((SUM([Sales Selected Year (copy)_1055531173139935251])/1000),1)) + &quot;K&quot;&#13;&#10;WHEN &quot;Orders&quot; THEN STR(COUNTD([Sales Selected Year (copy) (copy)_1055531173139943444]))&#13;&#10;END' />
            </column>
            <column caption='Metric Swap Change YoY' datatype='real' name='[Metric Swap Calc PY (Label) (copy)_1055531173175230491]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Sales&quot; THEN (SUM([Calculation_1055531173119102976])-SUM([Sales Selected Year (copy)_1055531173119610881]))/SUM([Sales Selected Year (copy)_1055531173119610881])&#13;&#10;WHEN &quot;Profit&quot; THEN (SUM([Sales Selected Year (copy)_1055531173139935251])-SUM([Sales Previous Year (copy)_1055531173139865616]))/SUM([Sales Previous Year (copy)_1055531173139865616])&#13;&#10;WHEN &quot;Orders&quot; THEN (COUNT([Sales Selected Year (copy) (copy)_1055531173139943444])-COUNT([Sales Previous Year (copy) (copy)_1055531173139894289]))/COUNT([Sales Previous Year (copy) (copy)_1055531173139894289])&#13;&#10;END' />
            </column>
            <column caption='Metric Swap Calc PY (Label)' datatype='string' name='[Metric Swap Calc PY (copy)_1055531173174919194]' role='measure' type='nominal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Sales&quot; THEN &quot;$&quot; + STR(ROUND((SUM([Sales Selected Year (copy)_1055531173119610881])/1000),1)) + &quot;K&quot;&#13;&#10;WHEN &quot;Profit&quot; THEN &quot;$&quot; + STR(ROUND((SUM([Sales Previous Year (copy)_1055531173139865616])/1000),1)) + &quot;K&quot;&#13;&#10;WHEN &quot;Orders&quot; THEN STR(COUNTD([Sales Previous Year (copy) (copy)_1055531173139894289]))&#13;&#10;END' />
            </column>
            <column caption='Metric Swap Change YoY Sign' datatype='real' default-format='*🡅;🡇' name='[Metric Swap Change YoY (copy)_1055531173176307740]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Sales&quot; THEN (SUM([Calculation_1055531173119102976])-SUM([Sales Selected Year (copy)_1055531173119610881]))/SUM([Sales Selected Year (copy)_1055531173119610881])&#13;&#10;WHEN &quot;Profit&quot; THEN (SUM([Sales Selected Year (copy)_1055531173139935251])-SUM([Sales Previous Year (copy)_1055531173139865616]))/SUM([Sales Previous Year (copy)_1055531173139865616])&#13;&#10;WHEN &quot;Orders&quot; THEN (COUNT([Sales Selected Year (copy) (copy)_1055531173139943444])-COUNT([Sales Previous Year (copy) (copy)_1055531173139894289]))/COUNT([Sales Previous Year (copy) (copy)_1055531173139894289])&#13;&#10;END' />
            </column>
            <column datatype='date' name='[Order Date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Order ID]' role='dimension' type='nominal' />
            <column datatype='real' name='[Profit]' role='measure' type='quantitative' />
            <column caption='Orders Previous Year' datatype='string' name='[Sales Previous Year (copy) (copy)_1055531173139894289]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 1]-1&#13;&#10;THEN [Order ID]&#13;&#10;END' />
            </column>
            <column caption='Profit Previous Year' datatype='real' name='[Sales Previous Year (copy)_1055531173139865616]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 1]-1&#13;&#10;THEN [Profit]&#13;&#10;END' />
            </column>
            <column caption='Orders Selected Year' datatype='string' name='[Sales Selected Year (copy) (copy)_1055531173139943444]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 1]&#13;&#10;THEN [Order ID]&#13;&#10;END' />
            </column>
            <column caption='Sales Previous Year' datatype='real' name='[Sales Selected Year (copy)_1055531173119610881]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 1]-1&#13;&#10;THEN [Sales]&#13;&#10;END' />
            </column>
            <column caption='Profit Selected Year' datatype='real' name='[Sales Selected Year (copy)_1055531173139935251]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date])=[Parameters].[Parameter 1]&#13;&#10;THEN [Profit]&#13;&#10;END' />
            </column>
            <column datatype='real' name='[Sales]' role='measure' type='quantitative' />
            <column caption='Previous Year' datatype='integer' name='[Selected Year (copy)_1055531173123981318]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Parameters].[Parameter 1]-1' />
            </column>
